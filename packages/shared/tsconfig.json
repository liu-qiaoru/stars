{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "types": ["node", "vitest"]
  },
  "include": [
    "schemas/**/*.ts",
    "constants/**/*.ts",
    "types/**/*.ts",
    "scripts/**/*.ts",
    "tests/**/*.ts"
  ]
}
