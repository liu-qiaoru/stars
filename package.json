{
  "name": "local-media-agent",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.12.1",
  "scripts": {
    "dev": "pnpm --parallel --filter './apps/*' dev",
    "check": "pnpm --recursive check",
    "lint": "eslint .",
    "format": "prettier \"**/*.{js,cjs,mjs,ts,tsx,json,css,yml,yaml}\" --write",
    "format:check": "prettier \"**/*.{js,cjs,mjs,ts,tsx,json,css,yml,yaml}\" --check"
  },
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=10.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.4.1",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.6.0",
    "prettier": "^3.8.3",
    "typescript-eslint": "^8.60.1"
  }
}
