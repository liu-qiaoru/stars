# Local API
SERVER_HOST=127.0.0.1
SERVER_PORT=4000

# Frontend API base URL (used by Next.js client-side code)
NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:4000

# PostgreSQL
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432
POSTGRES_DB=media_agent
POSTGRES_USER=media_agent
POSTGRES_PASSWORD=media_agent_dev
DATABASE_URL=postgres://media_agent:media_agent_dev@127.0.0.1:5432/media_agent

# Qdrant
QDRANT_URL=http://127.0.0.1:6333
QDRANT_HTTP_PORT=6333
QDRANT_GRPC_PORT=6334

# Optional Redis realtime channel
REDIS_URL=redis://127.0.0.1:6379
REDIS_PORT=6379

# Local media-agent storage
MEDIA_AGENT_HOME=.media-agent
MEDIA_AGENT_CACHE_DIR=.media-agent/cache
MEDIA_AGENT_EXPORT_DIR=.media-agent/exports
MEDIA_AGENT_LOG_DIR=.media-agent/logs
