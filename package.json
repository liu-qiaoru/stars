{
  "name": "local-media-agent",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.12.1",
  "scripts": {
    "dev": "pnpm --parallel --filter './apps/*' dev",
    "check": "pnpm --recursive check",
    "lint": "oxlint .",
    "lint:fix": "oxlint . --fix",
    "format": "oxfmt \"**/*.{js,cjs,mjs,ts,tsx,json,css,yml,yaml}\" --write",
    "format:check": "oxfmt \"**/*.{js,cjs,mjs,ts,tsx,json,css,yml,yaml}\" --check"
  },
  "devDependencies": {
    "oxfmt": "^0.55.0",
    "oxlint": "^1.70.0"
  },
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=10.0.0"
  }
}
