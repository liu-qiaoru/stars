# Local API
# Destructive developer tooling requires this exact marker and still defaults to dry-run.
MEDIA_AGENT_ENV=local
SERVER_HOST=127.0.0.1
SERVER_PORT=4000
JOB_COORDINATOR_ENABLED=true
JOB_COORDINATOR_INTERVAL_MS=5000
JOB_COORDINATOR_EMBEDDING_LIMIT=100
JOB_COORDINATOR_OCR_LIMIT=500

# Frontend API base URL (used by Next.js client-side code)
NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:4000

# PostgreSQL
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432
POSTGRES_DB=media_agent
POSTGRES_USER=media_agent
POSTGRES_PASSWORD=media_agent_dev
DATABASE_URL=postgres://media_agent:media_agent_dev@127.0.0.1:5432/media_agent

# Qdrant
QDRANT_URL=http://127.0.0.1:6333
QDRANT_HTTP_PORT=6333
QDRANT_GRPC_PORT=6334

# Local SigLIP model service for synchronous query embeddings
MODEL_SERVICE_URL=http://127.0.0.1:4020
MODEL_SERVICE_TIMEOUT_MS=10000
MODEL_SERVICE_HOST=127.0.0.1
MODEL_SERVICE_PORT=4020
SIGLIP_MODEL_NAME=google/siglip-base-patch16-224
SIGLIP_DEVICE=auto

# Optional caption indexing and local VLM service. The default backend reuses
# the model already downloaded by Ollama instead of downloading HF safetensors.
CAPTION_INDEXING_ENABLED=false
LOCAL_VLM_ENABLED=false
CAPTION_SEARCH_ENABLED=false
VIDEO_SEGMENT_SEARCH_ENABLED=true
LOCAL_VLM_SERVICE_URL=http://127.0.0.1:4030
LOCAL_VLM_SERVICE_HOST=127.0.0.1
LOCAL_VLM_SERVICE_PORT=4030
LOCAL_VLM_BACKEND=ollama
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_VLM_MODEL=qwen2.5vl:7b
LOCAL_VLM_MODEL_NAME=Qwen/Qwen2.5-VL-7B-Instruct
LOCAL_VLM_MODEL_VERSION=qwen2.5-vl-7b-instruct
LOCAL_VLM_TIMEOUT_SECONDS=120

# Video indexing. Dense is appropriate for small local libraries; switch to
# balanced or light before indexing very large video libraries.
KEYFRAME_DENSITY=dense
SCENE_MIN_SECONDS=3
SCENE_MAX_SECONDS=30
SCENE_MAX_COUNT=2000
SCENE_CAPTION_MAX_FRAMES=6

# Optional Redis realtime channel
REDIS_URL=redis://127.0.0.1:6379
REDIS_PORT=6379

# Agent LLM provider
ALLOW_EXTERNAL_LLM=false
ANTHROPIC_API_KEY=
AGENT_MODEL=disabled
AGENT_MAX_STEPS=4
AGENT_TOOL_TIMEOUT_MS=10000

# Optional search query expansion. When enabled, only the user's search query is
# sent to the provider; local media paths and search results are not included.
QUERY_EXPANSION_PROVIDER=none
QUERY_EXPANSION_TIMEOUT_MS=10000
QUERY_EXPANSION_MAX_VARIANTS=3
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-v4-flash

# Local media-agent storage
MEDIA_AGENT_HOME=.media-agent
MEDIA_AGENT_CACHE_DIR=.media-agent/cache
MEDIA_AGENT_EXPORT_DIR=.media-agent/exports
MEDIA_AGENT_LOG_DIR=.media-agent/logs
